# WhatsApp Cloud API Configuration
# Get your token from: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=your_whatsapp_access_token_here

# Get this from your WhatsApp Business Account in Meta Business Platform
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Create a custom verify token for webhook validation (any string you choose)
VERIFY_TOKEN=your_custom_verify_token_here

# Optional: WhatsApp Graph API version (defaults to v25.0)
WHATSAPP_GRAPH_API_VERSION=v25.0

# Optional: Test mode (set to "1" to use mock responses)
TEST_MODE=0

# Google Sheets Configuration
# Path to your Google service account JSON file (download from Google Cloud Console)
GOOGLE_CREDS_FILE=./credentials.json

# Google Sheet ID (found in the sheet URL)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Optional: Google Sheets retry configuration
GOOGLE_SHEETS_RETRIES=1
GOOGLE_SHEETS_RETRY_DELAY_SECONDS=1.0

# Session Management
# Session timeout in seconds (default: 1800 = 30 minutes)
SESSION_TIMEOUT_SECONDS=1800

# Coexistence mode (bot + human on same WhatsApp number)
WHATSAPP_COEXISTENCE_ENABLED=1
WHATSAPP_COEXISTENCE_AUTO_DETECT=1
HUMAN_OVERRIDE_TIMEOUT_SECONDS=1800

# Bot outbound tracking window used by coexistence status detection
BOT_OUTBOUND_MESSAGE_TTL_SECONDS=7200

# Protect /handoff endpoints with a shared token
HANDOFF_API_TOKEN=change_me_with_a_long_random_secret

# Optional IP/CIDR allowlist for /handoff endpoints (comma-separated)
# Examples: 203.0.113.10,198.51.100.0/24
HANDOFF_ALLOWED_SOURCES=

# Optional: Path to media cache file (defaults to media_cache.json)
WHATSAPP_MEDIA_CACHE_PATH=media_cache.json
